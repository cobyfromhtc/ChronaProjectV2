generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String?           @unique  // Optional - can use username only
  username         String            @unique
  password         String
  securityKey      String            // Account security key for verification
  avatarUrl        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  // ==================== ROLE SYSTEM ====================
  role             String            @default("user") // user, mod, admin, owner
  
  // ==================== CHRONOS CURRENCY SYSTEM ====================
  chronos            Int       @default(0)    // Current balance
  purchasedSlots     Int       @default(0)    // Extra persona slots purchased (25 free + this)
  nameColor          String?                  // Global name color (hex)
  dailyImagesUsed    Int       @default(0)    // Images sent today
  dailyImagesResetAt DateTime?                // When to reset daily image count
  hasFirstPurchaseBonus Boolean @default(false) // Whether they've used their first purchase bonus
  
  // Relations
  blockedBy        Block[]           @relation("UserBlockedBy")
  blockedUsers     Block[]           @relation("UserBlocked")
  following        Follow[]          @relation("UserFollowing")
  followers        Follow[]          @relation("UserFollowers")
  receivedRequests FriendRequest[]   @relation("ReceivedRequests")
  sentRequests     FriendRequest[]   @relation("SentRequests")
  friendsOf        Friendship[]      @relation("FriendOf")
  friends          Friendship[]      @relation("UserFriends")
  personas         Persona[]
  ownedStorylines  Storyline[]       @relation("StorylineOwner")
  storylineMembers StorylineMember[]
  chronosTransactions ChronosTransaction[]
  ownedThemes      ProfileTheme[]    @relation("ThemeOwner")
  notifications    Notification[]
}

model Persona {
  id                     String              @id @default(cuid())
  userId                 String
  name                   String
  avatarUrl              String?
  isActive               Boolean             @default(false)
  isOnline               Boolean             @default(false)
  description            String?
  archetype              String?
  gender                 String?
  pronouns               String?             // e.g., "he/him", "she/her", "they/them"
  age                    Int?
  tags                   String?
  personalityDescription String?
  personalitySpectrums   String?
  strengths              String?
  flaws                  String?
  values                 String?
  fears                  String?
  species                String?
  likes                  String?
  dislikes               String?
  hobbies                String?
  skills                 String?
  languages              String?
  habits                 String?
  speechPatterns         String?
  backstory              String?
  appearance             String?
  mbtiType               String?
  
  // Profile Theme (Chronos Purchase)
  themeId                String?             // Active profile theme
  themeEnabled           Boolean             @default(false) // Whether theme is currently displayed
  
  // Roleplay Preferences
  rpStyle                String?             // "one_liner", "semi_lit", "literate", "novella"
  rpPreferredGenders     String?             // JSON array: ["male", "female", "non_binary", "other"]
  rpGenres               String?             // JSON array of preferred genres
  rpLimits               String?             // JSON array of limits/triggers
  rpThemes               String?             // JSON array of preferred themes/topics
  rpExperienceLevel      String?             // "beginner", "intermediate", "advanced", "veteran"
  rpResponseTime         String?             // "instant", "same_day", "few_days", "weekly"
  
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  conversationsAsB       Conversation[]      @relation("ConversationB")
  conversationsAsA       Conversation[]      @relation("ConversationA")
  sentMessages           Message[]           @relation("MessageSender")
  storylineMessages      StorylineMessage[]
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections            PersonaConnection[]
  theme                  ProfileTheme?       @relation(fields: [themeId], references: [id], onDelete: SetNull)
  storylineBoosts        StorylineBoost[]
  sentDmRequests         DmRequest[]         @relation("DmRequestSender")
  receivedDmRequests     DmRequest[]         @relation("DmRequestReceiver")
}

model Conversation {
  id            String    @id @default(cuid())
  personaAId    String
  personaBId    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastMessageAt DateTime  @default(now())
  personaB      Persona   @relation("ConversationB", fields: [personaBId], references: [id], onDelete: Cascade)
  personaA      Persona   @relation("ConversationA", fields: [personaAId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@unique([personaAId, personaBId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String       @default("")
  imageUrl       String?
  createdAt      DateTime     @default(now())
  sender         Persona      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Friendship {
  id          String   @id @default(cuid())
  userId      String
  friendId    String
  isFavourite Boolean  @default(false)
  createdAt   DateTime @default(now())
  friend      User     @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)
  user        User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

// DM Request System - First-time DM requests need acceptance
model DmRequest {
  id              String    @id @default(cuid())
  senderId        String    // Persona who initiated the DM
  receiverId      String    // Persona who receives the request
  firstMessage    String    // The first message content
  imageUrl        String?   // Optional image with first message
  status          String    @default("pending") // "pending", "accepted", "ignored"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  sender          Persona   @relation("DmRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver        Persona   @relation("DmRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId])
  @@index([status])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("UserBlocked", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

// ==================== STORYLINE SYSTEM ====================

model Storyline {
  id             String              @id @default(cuid())
  ownerId        String
  name           String
  description    String?             // Short description
  lore           String?             // Detailed lore/backstory (NEW)
  iconUrl        String?
  bannerUrl      String?
  category       String
  
  // Customization (NEW)
  accentColor    String?             @default("#8b5cf6") // Theme color
  welcomeMessage String?             // Custom welcome message
  memberCap      Int?                // Max members limit
  requireApproval Boolean            @default(false) // Need approval to join
  
  // Boost System
  boostChronos   Int                 @default(0) // Total active boost Chronos
  boostTier      Int                 @default(0) // Current tier (0-13)
  
  isPublic       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  
  owner          User                @relation("StorylineOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  categories     StorylineCategory[]
  channels       StorylineChannel[]
  members        StorylineMember[]
  roles          StorylineRole[]
  invites        StorylineInvite[]
  bans           StorylineBan[]
  pinnedMessages StorylinePinnedMessage[]
  boosts         StorylineBoost[]

  @@index([category])
}

// Channel Categories (NEW)
model StorylineCategory {
  id          String            @id @default(cuid())
  storylineId String
  name        String
  position    Int               @default(0)
  collapsed   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  storyline   Storyline         @relation(fields: [storylineId], references: [id], onDelete: Cascade)
  channels    StorylineChannel[]

  @@unique([storylineId, name])
  @@index([storylineId])
}

model StorylineChannel {
  id          String             @id @default(cuid())
  storylineId String
  categoryId  String?            // Optional category (NEW)
  name        String
  type        String             @default("text")
  position    Int                @default(0)
  
  // Channel Settings (NEW)
  slowMode    Int?               @default(0) // Seconds between messages (0 = off)
  topic       String?            // Channel topic/description
  locked      Boolean            @default(false) // Only certain roles can post
  
  createdAt   DateTime           @default(now())
  storyline   Storyline          @relation(fields: [storylineId], references: [id], onDelete: Cascade)
  category    StorylineCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages    StorylineMessage[]
  permissions StorylineChannelPermission[]

  @@unique([storylineId, name])
  @@index([storylineId])
}

// Channel Permissions (NEW) - Which roles can access which channels
model StorylineChannelPermission {
  id        String           @id @default(cuid())
  channelId String
  roleId    String
  canView   Boolean          @default(true)
  canSend   Boolean          @default(true)
  channel   StorylineChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  role      StorylineRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([channelId, roleId])
}

model StorylineMember {
  id          String    @id @default(cuid())
  storylineId String
  userId      String
  roleId      String?   // Link to custom role (NEW)
  role        String    @default("member") // Legacy: owner, admin, member
  joinedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyline   Storyline @relation(fields: [storylineId], references: [id], onDelete: Cascade)
  customRole  StorylineRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([storylineId, userId])
  @@index([storylineId])
}

// Custom Roles (NEW)
model StorylineRole {
  id                String                      @id @default(cuid())
  storylineId       String
  name              String
  color             String                      @default("#8b5cf6")
  position          Int                         @default(0) // Higher = more important
  
  // Permissions
  canManageChannels Boolean                     @default(false)
  canManageRoles    Boolean                     @default(false)
  canKickMembers    Boolean                     @default(false)
  canBanMembers     Boolean                     @default(false)
  canManageMessages Boolean                     @default(false) // Delete others' messages
  canInvite         Boolean                     @default(true)
  canChangeSettings Boolean                     @default(false)
  isAdmin           Boolean                     @default(false) // Has all permissions
  
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  storyline         Storyline                   @relation(fields: [storylineId], references: [id], onDelete: Cascade)
  members           StorylineMember[]
  channelPermissions StorylineChannelPermission[]

  @@unique([storylineId, name])
  @@index([storylineId])
}

// Invite System (NEW)
model StorylineInvite {
  id          String    @id @default(cuid())
  storylineId String
  code        String    @unique
  createdById String
  maxUses     Int?      // Null = unlimited
  uses        Int       @default(0)
  expiresAt   DateTime? // Null = never expires
  createdAt   DateTime  @default(now())
  storyline   Storyline @relation(fields: [storylineId], references: [id], onDelete: Cascade)
  
  @@index([storylineId])
  @@index([code])
}

// Ban System (NEW)
model StorylineBan {
  id          String    @id @default(cuid())
  storylineId String
  userId      String
  bannedById  String
  reason      String?
  createdAt   DateTime  @default(now())
  storyline   Storyline @relation(fields: [storylineId], references: [id], onDelete: Cascade)

  @@unique([storylineId, userId])
  @@index([storylineId])
}

model StorylineMessage {
  id        String           @id @default(cuid())
  channelId String
  senderId  String
  content   String           @default("")
  imageUrl  String?
  createdAt DateTime         @default(now())
  channel   StorylineChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender    Persona          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  pinnedBy  StorylinePinnedMessage[]

  @@index([channelId])
  @@index([senderId])
}

// Pinned Messages (NEW)
model StorylinePinnedMessage {
  id        String           @id @default(cuid())
  storylineId String
  messageId String
  pinnedById String
  createdAt DateTime         @default(now())
  storyline Storyline        @relation(fields: [storylineId], references: [id], onDelete: Cascade)
  message   StorylineMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([storylineId, messageId])
  @@index([storylineId])
}

// Storyline Boost System
model StorylineBoost {
  id          String    @id @default(cuid())
  storylineId String
  personaId   String
  amount      Int       // 200, 500, or 1000
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  storyline   Storyline @relation(fields: [storylineId], references: [id], onDelete: Cascade)
  persona     Persona   @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([storylineId])
  @@index([personaId])
  @@index([expiresAt])
}

model PersonaConnection {
  id               String   @id @default(cuid())
  personaId        String
  characterName    String
  relationshipType String
  specificRole     String?
  characterAge     Int?
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  persona          Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([personaId])
}

// ==================== CHRONOS CURRENCY SYSTEM ====================

// Profile Themes (Purchasable with Chronos)
model ProfileTheme {
  id          String     @id @default(cuid())
  name        String
  description String?
  previewUrl  String?    // Preview image
  // Theme settings (stored as JSON-like strings)
  background  String?    // Background color/gradient
  borderColor String?    // Border color
  textColor   String?    // Text color
  accentColor String?    // Accent color
  backgroundImage String? // Optional background image URL
  
  // Pricing
  price       Int        @default(100)  // Cost in Chronos
  
  // System themes are available to everyone, user themes are custom
  isSystem    Boolean    @default(true)
  isActive    Boolean    @default(true) // Can be purchased
  
  createdAt   DateTime   @default(now())
  
  // Relations
  ownerId     String?
  owner       User?      @relation("ThemeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  personas    Persona[]
  
  @@index([isActive])
}

// Chronos Transaction History
model ChronosTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int                    // Positive = earned, Negative = spent
  balance     Int                    // Balance after transaction
  type        String                 // "purchase", "earn", "bonus", "spend", "admin"
  category    String                 // "slot", "storyline", "theme", "name_color", "daily_login", etc.
  description String
  
  // Reference to what was purchased (optional)
  referenceId String?                // ID of the item purchased (theme, etc.)
  
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ==================== ADMIN SYSTEM ====================

// Content Reports
model Report {
  id          String   @id @default(cuid())
  reporterId  String   // User who reported
  reportedId  String?  // User being reported (if user report)
  type        String   // "user", "storyline", "message", "persona"
  reason      String
  details     String?  // Additional details
  status      String   @default("pending") // pending, reviewed, resolved, dismissed
  
  // Reference info
  referenceId String?  // ID of the reported content
  
  // Review info
  reviewedById String?
  reviewedAt  DateTime?
  reviewNote  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// Admin Action Log
model AdminLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String   // "ban_user", "delete_content", "modify_chronos", etc.
  targetType  String   // "user", "storyline", "message", etc.
  targetId    String?
  details     String?  // JSON string with action details
  
  createdAt   DateTime @default(now())
  
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

// User Notifications
model Notification {
  id          String   @id @default(cuid())
  userId      String   // User who receives the notification
  type        String   // "chronos_reset", "chronos_grant", "chronos_deduct", "system", etc.
  title       String   // Short title
  message     String   // Full message/details
  
  // Additional data (JSON string)
  data        String?  // Extra info like amount, reason, admin name, etc.
  
  isRead      Boolean  @default(false)
  isDismissed Boolean  @default(false)
  
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}